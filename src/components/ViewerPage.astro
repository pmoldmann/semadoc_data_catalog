---
import '../styles/prose-content.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

/* Labels injected into the client-side script via define:vars */
const viewerLabels = JSON.stringify({
  /* doc_tabs – used by TAB_MAP */
  tab_model:       strings.doc_tabs.model,
  tab_table:       strings.doc_tabs.table,
  tab_measure:     strings.doc_tabs.measure,
  tab_import:      strings.doc_tabs.import,
  tab_calculation: strings.doc_tabs.calculation,
  tab_udf:         strings.doc_tabs.udf,
  tab_security:    strings.doc_tabs.security,
  /* doc_labels – used by mermaid / svg / fullscreen */
  mermaid_error:      strings.doc_labels.mermaid_error,
  zoom_out:           strings.doc_labels.zoom_out,
  zoom_in:            strings.doc_labels.zoom_in,
  fullscreen:         strings.doc_labels.fullscreen,
  close_esc:          strings.doc_labels.close_esc,
  pause_animation:    strings.doc_labels.pause_animation,
  resume_animation:   strings.doc_labels.resume_animation,
  svg_file_ref_unsupported: strings.doc_labels.svg_file_ref_unsupported,
  embed_toggle_title: strings.doc_labels.embed_toggle_title,
  embed_diagram:      strings.doc_labels.embed_diagram,
  unembed_diagram:    strings.doc_labels.unembed_diagram,
  print_title:        strings.doc_labels.print_title,
  columns_label:      strings.doc_labels.columns_label,
});
---

<BaseLayout
  title={strings.viewer.page_title}
  description={strings.viewer.page_description}
  locale={locale}
  currentPath="viewer"
>
  <script is:inline>(function(){if(localStorage.getItem('semadoc-theme')==='dark')document.documentElement.classList.add('dark');if(localStorage.getItem('semadoc-embed')==='true')document.documentElement.classList.add('embed-diagrams');})()</script>
  <section class="py-12 bg-neutral-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div id="page-header" class="mb-8">
        <div class="flex items-center justify-between">
          <div></div>
          <div class="flex items-center gap-2">
            <button id="embed-toggle" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title={strings.doc_labels.embed_toggle_title}>
              <svg class="embed-icon-expand w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>
              <svg class="embed-icon-collapse hidden w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20v-12m0 0L3 12m4-4l4 4m6-4V16m0 0l4-4m-4 4l-4-4" /></svg>
            </button>
            <button id="print-btn" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title={strings.doc_labels.print_title}>
              <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4H7v4a2 2 0 002 2zm0-16h6a2 2 0 012 2v2H7V5a2 2 0 012-2z" /></svg>
            </button>
            <button id="export-html-btn" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title={strings.doc_labels.export_html_title}>
              <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </button>
            <button id="dark-toggle" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title={strings.doc_labels.dark_toggle_title}>
              <svg class="dark-icon-moon w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
              <svg class="dark-icon-sun hidden w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </button>
          </div>
        </div>
        <p class="text-sm font-medium text-accent-600 mb-2 mt-4 tracking-wide uppercase">SemaDoc</p>
        <h1 class="text-3xl font-bold text-primary-700 mb-2">{strings.viewer.title}</h1>
        <p class="text-neutral-600">{strings.viewer.subtitle}</p>
      </div>

      <!-- Upload Area -->
      <div id="upload-area" class="mb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Left: File Upload -->
          <div>
            <div
              id="drop-zone"
              class="border-2 border-dashed border-neutral-300 rounded-xl p-10 text-center cursor-pointer transition-colors hover:border-accent-500 hover:bg-accent-50/30 h-full flex flex-col justify-center"
            >
              <svg class="w-12 h-12 mx-auto mb-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              <p class="text-lg font-semibold text-neutral-700 mb-1">{strings.viewer.drop_heading}</p>
              <p class="text-neutral-500 mb-3">{strings.viewer.drop_text}</p>
              <p class="text-xs text-neutral-400">{strings.viewer.drop_hint}</p>
              <input id="file-input" type="file" multiple accept=".md" class="hidden" />
            </div>
          </div>

          <!-- Right: Paste Markdown -->
          <div class="flex flex-col">
            <p class="text-lg font-semibold text-neutral-700 mb-2">{strings.viewer.paste_heading}</p>
            <textarea
              id="markdown-paste"
              class="flex-1 min-h-[200px] w-full rounded-xl border border-neutral-300 p-4 text-sm text-neutral-700 font-mono resize-y focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-accent-500 transition-colors"
              placeholder={strings.viewer.paste_placeholder}
            ></textarea>
            <button
              id="render-paste-btn"
              type="button"
              class="mt-3 w-full px-5 py-2.5 text-sm font-semibold text-white bg-accent-600 hover:bg-accent-700 rounded-lg transition-colors"
            >
              {strings.viewer.paste_render}
            </button>
          </div>
        </div>

        <p class="text-xs text-neutral-400 mt-3 flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          {strings.viewer.privacy_note}
        </p>
      </div>

      <!-- File status bar (shown after files loaded) -->
      <div id="file-status" class="hidden mb-6">
        <div class="flex items-center justify-between bg-white rounded-xl border border-neutral-100 shadow-sm px-6 py-4">
          <div>
            <p class="text-sm font-medium text-neutral-700">{strings.viewer.loaded_files}: <span id="file-count" class="text-accent-600 font-bold">0</span></p>
            <p id="model-title-display" class="text-lg font-bold text-primary-700 mt-1"></p>
          </div>
          <button id="reset-btn" type="button" class="px-4 py-2 text-sm font-medium text-neutral-600 bg-neutral-100 hover:bg-neutral-200 rounded-lg transition-colors">
            {strings.viewer.reset}
          </button>
        </div>
      </div>

      <!-- Tab Navigation (hidden until files loaded) -->
      <div id="tab-nav-wrapper" class="hidden border-b border-neutral-200 mb-8 overflow-x-auto">
        <nav class="flex gap-1 min-w-max" id="doc-tabs"></nav>
      </div>

      <!-- Tab Content -->
      <div id="tab-content"></div>
    </div>
  </section>

  <!-- Marked.js -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>

  <!-- Mermaid -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline>
    if (typeof mermaid !== 'undefined') {
      mermaid.initialize({
        startOnLoad: false,
        theme: document.documentElement.classList.contains('dark') ? 'dark' : 'default',
        securityLevel: 'loose',
        flowchart: { useMaxWidth: true },
        er: { useMaxWidth: true },
      });
    }
    window.noop = function() {};
  </script>

  <!-- highlight.js -->
  <link id="hljs-theme-light" rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/styles/github.min.css" />
  <link id="hljs-theme-dark" rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/styles/github-dark.min.css" disabled />
  <script is:inline>if(document.documentElement.classList.contains('dark')){var _l=document.getElementById('hljs-theme-light');var _d=document.getElementById('hljs-theme-dark');if(_l)_l.disabled=true;if(_d)_d.disabled=false;}</script>
  <script is:inline src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/highlight.min.js"></script>

  <!-- Inject localized labels for client-side JS -->
  <script is:inline define:vars={{ viewerLabels }}>
    window.__viewerLabels = JSON.parse(viewerLabels);
  </script>

  <!-- Styles -->
  <style is:global>
    /* ── ViewerPage-specific styles ── */
    /* Drop zone dark */
    html.dark #drop-zone { border-color: #475569; }
    html.dark #drop-zone:hover { border-color: #4dabf7; background-color: rgba(77, 171, 247, 0.05); }
    html.dark #drop-zone p.text-neutral-700 { color: #e2e8f0; }
    html.dark #drop-zone p.text-neutral-500 { color: #94a3b8; }
    html.dark #drop-zone p.text-neutral-400 { color: #64748b; }
    html.dark #drop-zone svg.text-neutral-400 { color: #64748b; }
    html.dark #file-status > div { background-color: #1e293b; border-color: #334155; }
    html.dark #file-status .text-neutral-700 { color: #e2e8f0; }
    html.dark #reset-btn { background-color: #334155; color: #cbd5e1; }
    html.dark #reset-btn:hover { background-color: #475569; }
    /* Paste area dark */
    html.dark #markdown-paste { background-color: #1e293b; border-color: #475569; color: #e2e8f0; }
    html.dark #markdown-paste::placeholder { color: #64748b; }
    html.dark #markdown-paste:focus { border-color: #4dabf7; ring-color: #4dabf7; }
    html.dark .flex.flex-col > p.text-neutral-700 { color: #e2e8f0; }
    /* Print: additional hidden elements */
    @media print {
      #upload-area, #file-status, #tab-nav-wrapper {
        display: none !important;
      }
    }
  </style>

  <script is:inline src="/scripts/semadoc-handlers.js"></script>
  <script is:inline>
  (function() {
    var L = window.__viewerLabels || {};

    initSemadocHandlers({
      labels: L,
      onMermaidRendered: null,
      getTitleForExport: function() {
        return (document.getElementById('model-title-display') || {}).textContent || 'SemaDoc-Export';
      }
    });

    /* ── File → tab mapping ── */
    var TAB_MAP = {
      'model_documentation.md':            { slug: 'model',       label: L.tab_model || 'Model Overview' },
      'table_documentation.md':            { slug: 'table',       label: L.tab_table || 'Tables & Columns' },
      'measure_documentation.md':          { slug: 'measure',     label: L.tab_measure || 'Measures' },
      'import_logic_documentation.md':     { slug: 'import',      label: L.tab_import || 'Import Logic' },
      'calculation_item_documentation.md': { slug: 'calculation', label: L.tab_calculation || 'Calculation Items' },
      'udf_documentation.md':              { slug: 'udf',         label: L.tab_udf || 'UDFs' },
      'security_documentation.md':         { slug: 'security',    label: L.tab_security || 'Security' },
    };

    var TAB_ORDER = ['model', 'table', 'measure', 'import', 'calculation', 'udf', 'security'];

    /* ── Configure marked with the same renderer as the static pages ── */
    function slugify(text) {
      return text.toLowerCase().replace(/<[^>]*>/g, '').replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
    }

    function fileToTabSlug(href) {
      return href.replace('_documentation.md', '').replace('import_logic', 'import').replace('calculation_item', 'calculation');
    }

    function sanitizeHtml(html) {
      var svgBlocks = [];
      var safe = html.replace(/<div class="svg-source"[^>]*>[\s\S]*?<\/div>/gi, function(m) {
        svgBlocks.push(m);
        return '<!--SVG_PLACEHOLDER_' + (svgBlocks.length - 1) + '-->';
      });
      var sanitized = safe
        .replace(/<(\/?)(style)(\s|>)/gi, '&lt;$1$2$3')
        .replace(/<(\/?)(script)(\s|>)/gi, '&lt;$1$2$3')
        .replace(/<abbr\s+title="([^"]*)">\s*ℹ️?\s*<\/abbr>/gi,
          function(_, tip) { return '<span class="info-tooltip" tabindex="0" title="' + tip + '"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25v2.25a.75.75 0 0 0 1.5 0V10a.75.75 0 0 0-.75-.75H9Z" clip-rule="evenodd"/></svg></span>'; });
      return sanitized.replace(/<!--SVG_PLACEHOLDER_(\d+)-->/g, function(_, i) { return svgBlocks[Number(i)]; });
    }

    var customRenderer = {
      heading: function(token) {
        var text = token.text;
        var depth = token.depth;
        var id = slugify(text);
        return '<h' + depth + ' id="' + id + '">' + text + '</h' + depth + '>';
      },
      code: function(token) {
        var text = token.text;
        var lang = token.lang;
        if (lang === 'mermaid') {
          return '<pre class="mermaid-source">' + text + '</pre>';
        }
        if (lang === 'svg') {
          if (text.trimStart().charAt(0) === '<') {
            var svgContent = text.replace(/<script[\s\S]*?<\/script\s*>/gi, '');
            var animated = /@keyframes|animation\s*:|animation-name\s*:|<animate[\s>]|<animateTransform[\s>]|<animateMotion[\s>]|<set[\s>]/.test(svgContent);
            return '<div class="svg-source" data-animated="' + animated + '">' + svgContent + '</div>';
          } else {
            return '<div class="text-sm text-amber-600 italic py-4">' + (L.svg_file_ref_unsupported || 'SVG file references are not supported in the viewer.') + '</div>';
          }
        }
        var langClass = lang ? ' class="language-' + lang + '"' : '';
        var escaped = text
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
        return '<pre><code' + langClass + '>' + escaped + '</code></pre>';
      },
      link: function(token) {
        var href = token.href;
        var text = token.text;
        if (href) {
          var hashIdx = href.indexOf('#');
          var filePart = hashIdx >= 0 ? href.substring(0, hashIdx) : href;
          var fragment = hashIdx >= 0 ? href.substring(hashIdx + 1) : '';
          if (filePart.endsWith('.md')) {
            var tabSlug = fileToTabSlug(filePart);
            var anchor = fragment || tabSlug;
            return '<a href="#' + anchor + '" class="text-accent-600 hover:text-accent-500 underline doc-tab-link" data-tab="' + tabSlug + '" data-anchor="' + fragment + '">' + text + '</a>';
          }
          if (href.startsWith('#')) {
            return '<a href="' + href + '" class="text-accent-600 hover:text-accent-500 underline">' + text + '</a>';
          }
        }
        return '<a href="' + href + '" class="text-accent-600 hover:text-accent-500 underline" target="_blank" rel="noopener noreferrer">' + text + '</a>';
      },
    };

    /* ── State ── */
    var loadedDocs = {}; // slug → { label, html }

    /* ── Wrap tables in scroll containers (post-processing) ── */
    function wrapTablesInScrollContainer(container) {
      container.querySelectorAll('table').forEach(function(table) {
        if (table.parentElement && table.parentElement.classList.contains('table-scroll-wrapper')) return;
        var wrapper = document.createElement('div');
        wrapper.className = 'table-scroll-wrapper';
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });
    }

    /* ── DOM refs ── */
    var dropZone = document.getElementById('drop-zone');
    var fileInput = document.getElementById('file-input');
    var uploadArea = document.getElementById('upload-area');
    var fileStatus = document.getElementById('file-status');
    var fileCount = document.getElementById('file-count');
    var modelTitleDisplay = document.getElementById('model-title-display');
    var tabNavWrapper = document.getElementById('tab-nav-wrapper');
    var docTabs = document.getElementById('doc-tabs');
    var tabContent = document.getElementById('tab-content');
    var resetBtn = document.getElementById('reset-btn');

    /* ── Drag & Drop ── */
    dropZone.addEventListener('click', function() { fileInput.click(); });
    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('border-accent-500', 'bg-accent-50/30');
    });
    dropZone.addEventListener('dragleave', function() {
      dropZone.classList.remove('border-accent-500', 'bg-accent-50/30');
    });
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('border-accent-500', 'bg-accent-50/30');
      handleFiles(e.dataTransfer.files);
    });
    fileInput.addEventListener('change', function() {
      handleFiles(fileInput.files);
    });

    /* ── Reset ── */
    resetBtn.addEventListener('click', function() {
      loadedDocs = {};
      uploadArea.classList.remove('hidden');
      fileStatus.classList.add('hidden');
      tabNavWrapper.classList.add('hidden');
      tabContent.innerHTML = '';
      docTabs.innerHTML = '';
      modelTitleDisplay.textContent = '';
      fileInput.value = '';
      var mdPaste = document.getElementById('markdown-paste');
      if (mdPaste) mdPaste.value = '';
    });

    /* ── Paste markdown rendering ── */
    var renderPasteBtn = document.getElementById('render-paste-btn');
    var markdownPaste = document.getElementById('markdown-paste');

    renderPasteBtn.addEventListener('click', function() {
      var content = markdownPaste.value.trim();
      if (!content) return;

      var markedInstance = new marked.Marked();
      markedInstance.use({ renderer: customRenderer });
      var html = sanitizeHtml(markedInstance.parse(content));

      // Show as a single panel (no tabs)
      loadedDocs = { paste: { label: 'Markdown', html: html } };
      uploadArea.classList.add('hidden');
      fileStatus.classList.remove('hidden');
      fileCount.textContent = '1';
      modelTitleDisplay.textContent = 'Markdown';

      tabNavWrapper.classList.add('hidden');
      docTabs.innerHTML = '';

      tabContent.innerHTML = '';
      var panel = document.createElement('div');
      panel.id = 'tab-paste';
      panel.className = 'doc-panel';
      panel.innerHTML = '<article class="prose prose-neutral max-w-none bg-white rounded-xl p-4 sm:p-6 lg:p-8 border border-neutral-100 shadow-sm">' + html + '</article>';
      wrapTablesInScrollContainer(panel);
      tabContent.appendChild(panel);

      initScrollIndicators();
      if (typeof hljs !== 'undefined') {
        registerCustomLanguages();
        hljs.highlightAll();
      }
      initMermaid();
      initSvgEmbeds();
      initSortableTables();
      initColumnToggle();
      addCopyButtons();
    });

    /* ── File handling ── */
    function handleFiles(fileList) {
      var files = Array.from(fileList).filter(function(f) { return f.name.endsWith('.md'); });
      if (files.length === 0) return;

      var pending = files.length;
      files.forEach(function(file) {
        var reader = new FileReader();
        reader.onload = function(e) {
          var content = e.target.result;
          var tabInfo = TAB_MAP[file.name];
          if (tabInfo) {
            var markedInstance = new marked.Marked();
            markedInstance.use({ renderer: customRenderer });
            var html = sanitizeHtml(markedInstance.parse(content));
            loadedDocs[tabInfo.slug] = { label: tabInfo.label, html: html };

            // Extract model title from model_documentation.md
            if (tabInfo.slug === 'model') {
              var m = content.match(/^#\s+(.+)/m);
              if (m) modelTitleDisplay.textContent = m[1].trim();
            }
          }
          pending--;
          if (pending === 0) renderViewer();
        };
        reader.readAsText(file);
      });
    }

    /* ── Render ── */
    function renderViewer() {
      var orderedSlugs = TAB_ORDER.filter(function(s) { return loadedDocs[s]; });
      if (orderedSlugs.length === 0) return;

      uploadArea.classList.add('hidden');
      fileStatus.classList.remove('hidden');
      fileCount.textContent = orderedSlugs.length;

      // Build tabs
      docTabs.innerHTML = '';
      orderedSlugs.forEach(function(slug, i) {
        var btn = document.createElement('button');
        btn.setAttribute('data-tab', slug);
        btn.className = 'doc-tab px-4 py-3 text-sm font-medium border-b-2 transition-colors whitespace-nowrap ' +
          (i === 0 ? 'border-accent-600 text-accent-600' : 'border-transparent text-neutral-500 hover:text-neutral-700 hover:border-neutral-300');
        btn.textContent = loadedDocs[slug].label;
        btn.addEventListener('click', function() { switchTab(slug); });
        docTabs.appendChild(btn);
      });
      tabNavWrapper.classList.remove('hidden');

      // Build panels
      tabContent.innerHTML = '';
      orderedSlugs.forEach(function(slug, i) {
        var panel = document.createElement('div');
        panel.id = 'tab-' + slug;
        panel.className = 'doc-panel' + (i === 0 ? '' : ' hidden');
        panel.innerHTML = '<article class="prose prose-neutral max-w-none bg-white rounded-xl p-4 sm:p-6 lg:p-8 border border-neutral-100 shadow-sm">' + loadedDocs[slug].html + '</article>';
        wrapTablesInScrollContainer(panel);
        tabContent.appendChild(panel);
      });

      // Post-processing
      initScrollIndicators();
      initDocTabLinks();
      if (typeof hljs !== 'undefined') {
        registerCustomLanguages();
        hljs.highlightAll();
      }
      initMermaid();
      initSvgEmbeds();
      initSortableTables();
      initColumnToggle();
      addCopyButtons();
    }

    function initDocTabLinks() {
      document.querySelectorAll('.doc-tab-link').forEach(function(link) {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          var tab = this.getAttribute('data-tab');
          var anchor = this.getAttribute('data-anchor');
          switchTab(tab);
          if (anchor) {
            setTimeout(function() {
              var target = document.getElementById(anchor);
              if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 80);
          } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      });
    }

    /* ── Tab switching ── */
    function switchTab(tab) {
      document.querySelectorAll('.doc-tab').forEach(function(b) {
        b.classList.remove('border-accent-600', 'text-accent-600');
        b.classList.add('border-transparent', 'text-neutral-500');
      });
      document.querySelectorAll('.doc-panel').forEach(function(p) {
        p.classList.add('hidden');
      });

      var activeBtn = document.querySelector('.doc-tab[data-tab="' + tab + '"]');
      if (activeBtn) {
        activeBtn.classList.add('border-accent-600', 'text-accent-600');
        activeBtn.classList.remove('border-transparent', 'text-neutral-500');
      }
      var activePanel = document.getElementById('tab-' + tab);
      if (activePanel) {
        activePanel.classList.remove('hidden');
        initMermaid();
        initSvgEmbeds();
      }
      initScrollIndicators();
      initSortableTables();
      initColumnToggle();
      addCopyButtons();
    }
  })();
  </script>
</BaseLayout>
