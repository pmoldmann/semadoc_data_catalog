    html.dark #help-modal p { color: #94a3b8; }
    html.dark #help-modal .bg-neutral-50 { background-color: #0f172a; }
    html.dark #help-modal .border-neutral-100 { border-color: #334155; }
    html.dark #help-modal h3 { color: #e2e8f0; }
    html.dark #help-modal svg.text-neutral-500 { color: #94a3b8; }
    html.dark #help-toggle { background-color: #1e293b; border-color: #475569; }
    html.dark #help-toggle:hover { background-color: #334155; }
    html.dark #help-toggle svg { color: #e2e8f0; }
  </style>

  <script is:inline>
    var LOCALE = 'en';
    var searchIndex = null;
    var searchTimeout = null;

    // Model selection
    document.querySelectorAll('.model-item').forEach(function(btn) {
      btn.addEventListener('click', function() {
        selectModel(this.getAttribute('data-model'));
      });
    });

    // Workspace filtering
    var wsFilter = document.getElementById('workspace-filter');
    if (wsFilter) {
      wsFilter.addEventListener('change', function() {
        filterByWorkspace(this.value);
      });
    }

    function filterByWorkspace(ws) {
      var items = document.querySelectorAll('.model-item');
      var firstVisible = null;
      items.forEach(function(btn) {
        var itemWs = btn.getAttribute('data-workspace');
        var visible = !ws || itemWs === ws;
        btn.style.display = visible ? '' : 'none';
        if (visible && !firstVisible) firstVisible = btn;
      });
      // Select first visible model
      if (firstVisible) {
        selectModel(firstVisible.getAttribute('data-model'));
      }
    }

    function selectModel(slug) {
      // Update button styles
      document.querySelectorAll('.model-item').forEach(function(b) {
        b.classList.remove('border-accent-400', 'shadow-sm', 'ring-1', 'ring-accent-400/20');
        b.classList.add('border-neutral-100');
      });
      var activeBtn = document.querySelector('.model-item[data-model="' + slug + '"]');
      if (activeBtn) {
        activeBtn.classList.add('border-accent-400', 'shadow-sm', 'ring-1', 'ring-accent-400/20');
        activeBtn.classList.remove('border-neutral-100');
      }

      // Show preview
      document.querySelectorAll('.model-preview').forEach(function(p) {
        p.classList.add('hidden');
      });
      var preview = document.getElementById('preview-' + slug);
      if (preview) {
        preview.classList.remove('hidden');
        initMermaid();
        initSvgEmbeds();
      }
    }

    // Search
    var searchInput = document.getElementById('catalog-search');
    var clearBtn = document.getElementById('clear-search');
    var searchResults = document.getElementById('search-results');
    var catalogBrowser = document.getElementById('catalog-browser');
    var searchHeading = document.getElementById('search-results-heading');
    var searchContent = document.getElementById('search-results-content');

    searchInput.addEventListener('input', function() {
      var query = this.value.trim();
      clearBtn.classList.toggle('hidden', query.length === 0);

      clearTimeout(searchTimeout);
      if (query.length < 2) {
        showCatalog();
        return;
      }
      searchTimeout = setTimeout(function() { performSearch(query); }, 300);
    });

    clearBtn.addEventListener('click', function() {
      searchInput.value = '';
      clearBtn.classList.add('hidden');
      showCatalog();
      searchInput.focus();
    });

    function showCatalog() {
      searchResults.classList.add('hidden');
      catalogBrowser.classList.remove('hidden');
      closePreview();
    }

    function showSearchResults() {
      searchResults.classList.remove('hidden');
      catalogBrowser.classList.add('hidden');
    }

    async function loadSearchIndex() {
      if (searchIndex) return searchIndex;
      var resp = await fetch('/search-index.json');
      searchIndex = await resp.json();
      return searchIndex;
    }

    function slugifyHeading(text) {
      return text.toLowerCase().replace(/<[^>]*>/g, '').replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
    }

    function escapeHtml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function highlightMatch(text, query) {
      var idx = text.toLowerCase().indexOf(query.toLowerCase());
      if (idx === -1) return escapeHtml(text);
      var before = escapeHtml(text.substring(0, idx));
      var match = escapeHtml(text.substring(idx, idx + query.length));
      var after = escapeHtml(text.substring(idx + query.length));
      return before + '<mark class="bg-yellow-200 rounded px-0.5">' + match + '</mark>' + after;
    }

    function getSnippet(text, query, contextLen) {
      contextLen = contextLen || 80;
      var lower = text.toLowerCase();
      var idx = lower.indexOf(query.toLowerCase());
      if (idx === -1) return '';
      var start = Math.max(0, idx - contextLen);
      var end = Math.min(text.length, idx + query.length + contextLen);
      var snippet = (start > 0 ? '…' : '') + text.substring(start, end) + (end < text.length ? '…' : '');
      return highlightMatch(snippet, query);
    }

    function renderSnippet(m, query, model, file, docUrl, curIdx) {
      var snippet = getSnippet(m.text, query);
      // If query matched only in heading, show a snippet from the beginning of the body text
      if (!snippet && m.heading && m.heading.toLowerCase().indexOf(query.toLowerCase()) !== -1) {
        var bodyPreview = m.text.length > 200 ? m.text.substring(0, 200) + '…' : m.text;
        snippet = escapeHtml(bodyPreview);
      }
      if (!snippet) return '';
      var html = '<div class="search-result-item group bg-white rounded-lg border border-neutral-100 p-3 text-sm text-neutral-600 cursor-pointer hover:border-accent-300 hover:shadow-sm transition-all" data-idx="' + curIdx + '">';
      if (m.heading) {
        html += '<div class="text-xs font-medium text-neutral-400 mb-1">' + highlightMatch(escapeHtml(m.heading), query) + '</div>';
      }
      html += '<div>' + snippet + '</div>';
      html += '<div class="flex items-center gap-3 mt-2 pt-2 border-t border-neutral-50">';
      html += '<button type="button" class="preview-btn inline-flex items-center gap-1 text-xs font-medium text-accent-600 hover:text-accent-500 transition-colors">';
      html += '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>';
      html += (LOCALE === 'de' ? 'Vorschau' : 'Preview');
      html += '</button>';
      html += '<a href="' + escapeHtml(docUrl) + '" class="inline-flex items-center gap-1 text-xs font-medium text-neutral-400 hover:text-accent-600 transition-colors">';
      html += '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>';
      html += (LOCALE === 'de' ? 'Zum Dokument →' : 'Go to document →');
      html += '</a>';
      html += '</div>';
      html += '</div>';
      return html;
    }

    async function performSearch(query) {
      var index = await loadSearchIndex();
      var totalMatches = 0;
      var lowerQuery = query.toLowerCase();

      // Group by workspace → model → file
      var workspaces = {};
      for (var i = 0; i < index.length; i++) {
        var entry = index[i];
        var fileMatches = [];
        for (var j = 0; j < entry.sections.length; j++) {
          var section = entry.sections[j];
          if (section.text.toLowerCase().indexOf(lowerQuery) !== -1 ||
              section.heading.toLowerCase().indexOf(lowerQuery) !== -1) {
            fileMatches.push(section);
            totalMatches++;
          }
        }
        if (fileMatches.length > 0) {
          var ws = entry.workspace || (LOCALE === 'de' ? 'Ohne Workspace' : 'No Workspace');
          if (!workspaces[ws]) workspaces[ws] = {};
          if (!workspaces[ws][entry.model]) {
            workspaces[ws][entry.model] = { modelTitle: entry.modelTitle, workspaceSlug: entry.workspaceSlug || entry.model, modelSlug: entry.modelSlug || entry.model, files: {} };
          }
          var fileLabel = LOCALE === 'de' ? entry.fileLabelDe : entry.fileLabelEn;
          workspaces[ws][entry.model].files[entry.file] = {
            label: fileLabel,
            slug: entry.fileSlug,
            matches: fileMatches,
          };
        }
      }

      // Render results
      searchHeading.textContent = (LOCALE === 'de' ? 'Suchergebnisse für' : 'Search results for') +
        ' "' + query + '" (' + totalMatches + ' ' + (LOCALE === 'de' ? 'Treffer' : 'matches') + ')';

      if (totalMatches === 0) {
        searchContent.innerHTML = '<div class="text-center text-neutral-400 py-12">' +
          (LOCALE === 'de' ? 'Keine Treffer gefunden.' : 'No results found.') + '</div>';
        showSearchResults();
        return;
      }

      var html = '';
      searchResultData = [];
      var wsKeys = Object.keys(workspaces).sort();
      var wsCounter = 0;

      for (var wi = 0; wi < wsKeys.length; wi++) {
        var wsName = wsKeys[wi];
        var wsModels = workspaces[wsName];
        var wsId = 'ws-' + (wsCounter++);

        // Workspace group
        html += '<details class="mb-6" open>';
        html += '<summary class="flex items-center gap-2 cursor-pointer select-none group mb-3">';
        html += '<svg class="w-4 h-4 text-neutral-400 transition-transform group-open:rotate-90 search-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>';
        html += '<svg class="w-5 h-5 text-accent-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>';
        html += '<h3 class="text-base font-bold text-primary-700">' + escapeHtml(wsName) + '</h3>';
        html += '</summary>';

        for (var model in wsModels) {
          var r = wsModels[model];

          // Model group (nested collapsible)
          html += '<details class="ml-4 mb-4" open>';
          html += '<summary class="flex items-center gap-2 cursor-pointer select-none group mb-2">';
          html += '<svg class="w-3.5 h-3.5 text-neutral-400 transition-transform group-open:rotate-90 search-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>';
          html += '<svg class="w-4 h-4 text-accent-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4" /></svg>';
          html += '<h4 class="text-sm font-bold text-primary-700">' + escapeHtml(r.modelTitle) + '</h4>';
          html += '</summary>';

          for (var file in r.files) {
            var f = r.files[file];
            var baseUrl = '/' + LOCALE + '/docs-example/' + r.workspaceSlug + '/' + r.modelSlug;
            html += '<div class="ml-6 mb-4">';
            html += '<div class="flex items-center gap-2">';
            html += '<svg class="w-4 h-4 flex-shrink-0 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>';
            html += '<span class="text-sm font-semibold text-accent-600">' + escapeHtml(f.label) + '</span>';
            html += '</div>';
            html += '<div class="mt-2 space-y-2">';

            var maxSnippets = Math.min(f.matches.length, 5);
            for (var k = 0; k < maxSnippets; k++) {
              var curIdx = searchResultData.length;
              var headingSlug = f.matches[k].heading ? slugifyHeading(f.matches[k].heading) : '';
              var occ = f.matches[k].headingOccurrence || 0;
              var hash = headingSlug ? f.slug + '__' + headingSlug + (occ > 0 ? '__' + occ : '') : f.slug;
              var docUrl = baseUrl + '#' + hash;
              searchResultData.push({ model: model, file: file, heading: f.matches[k].heading, query: query, docUrl: docUrl, sectionText: f.matches[k].text, headingOccurrence: occ });
              html += renderSnippet(f.matches[k], query, model, file, docUrl, curIdx);
            }
            if (f.matches.length > maxSnippets) {
              var moreCount = f.matches.length - maxSnippets;
              var moreId = 'more-' + model.replace(/[^a-zA-Z0-9]/g, '_') + '-' + file.replace(/[^a-zA-Z0-9]/g, '_');
              html += '<div id="' + moreId + '" class="hidden space-y-2">';
              for (var k = maxSnippets; k < f.matches.length; k++) {
                var curIdx = searchResultData.length;
                var headingSlug = f.matches[k].heading ? slugifyHeading(f.matches[k].heading) : '';
                var occ = f.matches[k].headingOccurrence || 0;
                var hash = headingSlug ? f.slug + '__' + headingSlug + (occ > 0 ? '__' + occ : '') : f.slug;
                var docUrl = baseUrl + '#' + hash;
                searchResultData.push({ model: model, file: file, heading: f.matches[k].heading, query: query, docUrl: docUrl, sectionText: f.matches[k].text, headingOccurrence: occ });
                html += renderSnippet(f.matches[k], query, model, file, docUrl, curIdx);
              }
              html += '</div>';
              html += '<a href="#" class="show-more-link text-xs text-accent-600 hover:text-accent-500 pl-3 cursor-pointer" data-target="' + moreId + '">+ ' + moreCount + ' ' + (LOCALE === 'de' ? 'weitere Treffer anzeigen' : 'more matches') + '</a>';
            }

            html += '</div></div>';
          }
          html += '</details>';
        }
        html += '</details>';
      }
      searchContent.innerHTML = html;

      // Attach preview click handlers
      searchContent.querySelectorAll('.search-result-item').forEach(function(item) {
        var previewBtn = item.querySelector('.preview-btn');
        if (previewBtn) {
          previewBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            showPreview(parseInt(item.dataset.idx));
          });
        }
      });

      // Attach show-more click handlers
      searchContent.querySelectorAll('.show-more-link').forEach(function(link) {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById(this.getAttribute('data-target'));
          if (target) {
            target.classList.remove('hidden');
            // Attach preview handlers to newly visible items
            target.querySelectorAll('.search-result-item').forEach(function(item) {
              var previewBtn = item.querySelector('.preview-btn');
              if (previewBtn) {
                previewBtn.addEventListener('click', function(ev) {
                  ev.stopPropagation();
                  showPreview(parseInt(item.dataset.idx));
                });
              }
            });
          }
          this.style.display = 'none';
        });
      });

      showSearchResults();
    }

    // ── Preview panel logic ──
    var previewPanel = document.getElementById('search-preview-panel');
    var previewHeading = document.getElementById('preview-heading');
    var previewContent = document.getElementById('preview-content');
    var previewOpenLink = document.getElementById('preview-open-link');
    var previewCloseBtn = document.getElementById('preview-close');
    var mdCache = {};
    var searchResultData = [];

    if (previewCloseBtn) {
      previewCloseBtn.addEventListener('click', closePreview);
    }

    function closePreview() {
      previewPanel.classList.add('hidden');
      // Deselect active result
      searchContent.querySelectorAll('.search-result-item').forEach(function(el) {
        el.classList.remove('ring-2', 'ring-accent-400', 'border-accent-400');
      });
    }

    async function fetchMarkdown(model, file) {
      var cacheKey = model + '/' + file;
      if (mdCache[cacheKey]) return mdCache[cacheKey];
      var fileSlug = file.replace('.md', '');
      var url = '/api/md/' + encodeURIComponent(model) + '/' + encodeURIComponent(fileSlug) + '.json';
      var resp = await fetch(url);
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      var data = await resp.json();
      mdCache[cacheKey] = data.content;
      return data.content;
    }

    function extractContext(mdText, heading, query, contextLines, sectionText, headingOccurrence) {
      contextLines = contextLines || 15;
      var lines = mdText.split('\n');

      // Find the line that contains the query match
      var lowerQuery = query.toLowerCase();
      var matchLineIdx = -1;

      // First try to find the match within the matching heading's section
      var sectionStart = -1;
      var sectionEnd = lines.length;

      if (heading) {
        // Collect all candidate heading positions
        var candidates = [];
        for (var i = 0; i < lines.length; i++) {
          if (lines[i].replace(/^#+\s+/, '').trim() === heading) {
            var level = (lines[i].match(/^(#+)/) || ['', '#'])[1].length;
            var secEnd = lines.length;
            for (var j = i + 1; j < lines.length; j++) {
              var hMatch = lines[j].match(/^(#+)\s/);
              if (hMatch && hMatch[1].length <= level) {
                secEnd = j;
                break;
              }
            }
            candidates.push({ start: i, end: secEnd });
          }
        }

        // Use headingOccurrence to pick the right candidate directly
        var occ = typeof headingOccurrence === 'number' ? headingOccurrence : 0;
        if (candidates.length > 0) {
          var pick = Math.min(occ, candidates.length - 1);
          sectionStart = candidates[pick].start;
          sectionEnd = candidates[pick].end;
        }
      }

      // Search within the section first, then globally
      var searchStart = sectionStart >= 0 ? sectionStart : 0;
      var searchEnd = sectionStart >= 0 ? sectionEnd : lines.length;

      for (var i = searchStart; i < searchEnd; i++) {
        if (lines[i].toLowerCase().indexOf(lowerQuery) !== -1) {
          matchLineIdx = i;
          break;
        }
      }

      // Fallback: search globally if not found in section
      if (matchLineIdx === -1) {
        for (var i = 0; i < lines.length; i++) {
          if (lines[i].toLowerCase().indexOf(lowerQuery) !== -1) {
            matchLineIdx = i;
            break;
          }
        }
      }

      if (matchLineIdx === -1) {
        // If still not found, show the heading's section or beginning
        if (sectionStart >= 0) {
          matchLineIdx = sectionStart;
        } else {
          matchLineIdx = 0;
        }
      }

      // Expand context to include full sections (don't cut in the middle of tables/lists)
      var start = Math.max(0, matchLineIdx - contextLines);
      var end = Math.min(lines.length, matchLineIdx + contextLines + 1);

      // Extend start backwards to the nearest heading for context
      for (var i = start; i >= Math.max(0, start - 10); i--) {
        if (/^#+\s/.test(lines[i])) {
          start = i;
          break;
        }
      }

      // Regex matching code fences (optionally indented up to 3 spaces)
      var fenceRe = /^\s{0,3}```/;

      // Ensure start doesn't cut into an open code block
      // Count fences from document start to our start line
      var fencesBefore = 0;
      for (var i = 0; i < start; i++) {
        if (fenceRe.test(lines[i])) fencesBefore++;
      }
      if (fencesBefore % 2 === 1) {
        // start is inside a code block — move start back to its opening fence
        for (var i = start - 1; i >= 0; i--) {
          if (fenceRe.test(lines[i])) {
            start = i;
            break;
          }
        }
      }

      // Ensure end doesn't cut into an open code block
      var inCodeBlock = false;
      for (var i = start; i < end; i++) {
        if (fenceRe.test(lines[i])) inCodeBlock = !inCodeBlock;
      }
      if (inCodeBlock) {
        // Find closing code fence — no limit, include the entire block
        for (var i = end; i < lines.length; i++) {
          end = i + 1;
          if (fenceRe.test(lines[i])) break;
        }
      }

      var contextMd = lines.slice(start, end).join('\n');
      var hasMore = start > 0 || end < lines.length;
      return { markdown: contextMd, hasMore: hasMore, startLine: start, endLine: end, matchLine: matchLineIdx };
    }

    function highlightInHtml(html, query) {
      if (!query) return html;
      // Only highlight in text nodes, not inside HTML tags
      var escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      var re = new RegExp('(>)([^<]*?)(' + escaped + ')([^<]*?)(<)', 'gi');
      return html.replace(re, function(match, pre, before, term, after, post) {
        return pre + before + '<mark class="bg-yellow-200 rounded px-0.5">' + term + '</mark>' + after + post;
      });
    }

    async function showPreview(idx) {
      var d = searchResultData[idx];
      if (!d) return;
      var model = d.model, file = d.file, heading = d.heading, query = d.query, docUrl = d.docUrl, sectionText = d.sectionText, headingOccurrence = d.headingOccurrence;

      // Highlight active result
      searchContent.querySelectorAll('.search-result-item').forEach(function(el) {
        el.classList.remove('ring-2', 'ring-accent-400', 'border-accent-400');
      });
      var activeItem = searchContent.querySelector('.search-result-item[data-idx="' + idx + '"]');
      if (activeItem) {
        activeItem.classList.add('ring-2', 'ring-accent-400', 'border-accent-400');
      }

      // Show panel with loading state
      previewPanel.classList.remove('hidden');
      previewContent.innerHTML = '<div class="text-center text-neutral-400 py-8">' +
        (LOCALE === 'de' ? 'Vorschau wird geladen…' : 'Loading preview…') + '</div>';

      // Set heading and link
      var fileLabels = {
        'model_documentation.md': LOCALE === 'de' ? 'Modell-Übersicht' : 'Model Overview',
        'table_documentation.md': LOCALE === 'de' ? 'Tabellen & Spalten' : 'Tables & Columns',
        'measure_documentation.md': 'Measures',
        'import_logic_documentation.md': LOCALE === 'de' ? 'Import-Logik' : 'Import Logic',
        'calculation_item_documentation.md': 'Calculation Items',
        'udf_documentation.md': 'UDFs',
      };
      previewHeading.textContent = (fileLabels[file] || file) + (heading ? ' › ' + heading : '');
      previewOpenLink.href = docUrl;

      try {
        var mdText = await fetchMarkdown(model, file);
        var ctx = extractContext(mdText, heading, query, 15, sectionText, headingOccurrence);
        var rawHtml = '';

        if (typeof marked !== 'undefined') {
          rawHtml = marked.parse(ctx.markdown)
            .replace(/<(\/?)(style)(\s|>)/gi, '&lt;$1$2$3')
            .replace(/<(\/?)(script)(\s|>)/gi, '&lt;$1$2$3');
        } else {
          rawHtml = '<pre class="whitespace-pre-wrap text-sm">' + escapeHtml(ctx.markdown) + '</pre>';
        }

        var highlighted = highlightInHtml(rawHtml, query);

        var output = '';
        if (ctx.startLine > 0) {
          output += '<div class="text-xs text-neutral-400 mb-3 pb-2 border-b border-neutral-100">⋯ ' +
            (LOCALE === 'de' ? 'Inhalt davor ausgeblendet' : 'Content above hidden') + '</div>';
        }
        output += highlighted;
        if (ctx.endLine < mdText.split('\n').length) {
          output += '<div class="text-xs text-neutral-400 mt-3 pt-2 border-t border-neutral-100">⋯ ' +
            (LOCALE === 'de' ? 'Inhalt danach ausgeblendet' : 'Content below hidden') + '</div>';
        }
        previewContent.innerHTML = output;

        // Scroll to first highlight
        var firstMark = previewContent.querySelector('mark');
        if (firstMark) {
          setTimeout(function() { firstMark.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
        }
      } catch (err) {
        previewContent.innerHTML = '<div class="text-center text-red-400 py-8">' +
          (LOCALE === 'de' ? 'Vorschau konnte nicht geladen werden.' : 'Preview could not be loaded.') + '</div>';
      }
    }

    // Mermaid rendering for previews
    async function initMermaid() {
      if (typeof mermaid === 'undefined') return;
      var sources = document.querySelectorAll('.model-preview:not(.hidden) .mermaid-source');
      if (sources.length === 0) return;
      for (var i = 0; i < sources.length; i++) {
        var el = sources[i];
        if (!el.getAttribute('data-mmd-src')) el.setAttribute('data-mmd-src', el.textContent);
        el.classList.remove('mermaid-source');
        el.classList.add('mermaid');
        try {
          await mermaid.run({ nodes: [el] });
          wrapMermaidDiagram(el);
          rewriteMermaidLinks(el);
        } catch (err) {
          console.warn('Mermaid rendering error:', err);
          el.classList.add('mermaid-error');
          el.innerHTML = '<div class="text-sm text-neutral-400 italic py-4">Diagram could not be rendered</div>';
        }
      }
    }

    /* ── Rewrite Mermaid click-href links (rendered as SVG <a>) ── */
    function rewriteMermaidLinks(el) {
      var svgEl = el.tagName === 'svg' ? el : el.querySelector('svg');
      if (!svgEl) return;
      var previewDiv = el.closest('.model-preview');
      var baseUrl = previewDiv ? previewDiv.getAttribute('data-model-url') : '';
      if (!baseUrl) return;
      var links = svgEl.querySelectorAll('a');
      for (var i = 0; i < links.length; i++) {
        var a = links[i];
        var href = a.getAttribute('href') || a.getAttributeNS('http://www.w3.org/1999/xlink', 'href') || '';
        var match = href.match(/^(\w+_documentation\.md)(?:#(.+))?$/);
        if (!match) continue;
        var filePart = match[1];
        var fragment = match[2] || '';
        var tabSlug = filePart.replace('_documentation.md', '').replace('import_logic', 'import').replace('calculation_item', 'calculation');
        var newHash = fragment ? tabSlug + '__' + fragment : tabSlug;
        var newUrl = baseUrl + '#' + newHash;
        a.setAttribute('href', newUrl);
        if (a.hasAttributeNS('http://www.w3.org/1999/xlink', 'href')) {
          a.setAttributeNS('http://www.w3.org/1999/xlink', 'href', newUrl);
        }
      }
    }

