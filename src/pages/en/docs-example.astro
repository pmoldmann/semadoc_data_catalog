---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Marked } from 'marked';
import { t } from '../../i18n';
import fs from 'node:fs';
import path from 'node:path';
import { toUrlSlug, extractModelTitle, extractWorkspace } from '../../utils/slug';

const locale = 'en';
const strings = t(locale);

const docsDir = path.resolve('src/data/markdown');
const modelDirs = fs.readdirSync(docsDir).filter(d =>
  fs.statSync(path.join(docsDir, d)).isDirectory()
);

function createMarked(workspaceSlug: string, modelSlug: string, modelPath: string) {
  const m = new Marked();
  m.use({
    renderer: {
      code({ text, lang }: { text: string; lang?: string }) {
        if (lang === 'mermaid') {
          return `<pre class="mermaid-source">${text}</pre>`;
        }
        if (lang === 'svg') {
          let svgContent = '';
          if (text.trimStart().startsWith('<')) {
            svgContent = text.replace(/<script[\s\S]*?<\/script\s*>/gi, '');
          } else {
            const fileName = text.trim();
            if (!/^[\w.\-]+\.svg$/i.test(fileName)) {
              return `<div class="text-sm text-red-500 italic py-4">Invalid SVG filename: ${fileName.replace(/</g, '&lt;')}</div>`;
            }
            const svgFilePath = path.join(modelPath, fileName);
            if (!fs.existsSync(svgFilePath)) {
              return `<div class="text-sm text-red-500 italic py-4">SVG file not found: ${fileName}</div>`;
            }
            svgContent = fs.readFileSync(svgFilePath, 'utf-8').replace(/<script[\s\S]*?<\/script\s*>/gi, '');
          }
          const animated = /@keyframes|animation\s*:|animation-name\s*:|<animate[\s>]|<animateTransform[\s>]|<animateMotion[\s>]|<set[\s>]/.test(svgContent);
          return `<div class="svg-source" data-animated="${animated}">${svgContent}</div>`;
        }
        const langClass = lang ? ` class="language-${lang}"` : '';
        const escaped = text
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
        return `<pre><code${langClass}>${escaped}</code></pre>`;
      },
      link({ href, text }: { href: string; text: string }) {
        if (href) {
          const hashIdx = href.indexOf('#');
          const filePart = hashIdx >= 0 ? href.substring(0, hashIdx) : href;
          const fragment = hashIdx >= 0 ? href.substring(hashIdx + 1) : '';
          if (filePart.endsWith('.md')) {
            const tabSlug = filePart.replace('_documentation.md', '').replace('import_logic', 'import').replace('calculation_item', 'calculation');
            const anchor = fragment || tabSlug;
            return `<a href="/${locale}/docs-example/${workspaceSlug}/${modelSlug}#${anchor}" class="text-accent-600 hover:text-accent-500 underline">${text}</a>`;
          }
          if (href.startsWith('#')) {
            return `<a href="${href}" class="text-accent-600 hover:text-accent-500 underline">${text}</a>`;
          }
        }
        return `<a href="${href}" class="text-accent-600 hover:text-accent-500 underline" target="_blank" rel="noopener noreferrer">${text}</a>`;
      },
    },
  });
  return m;
}

function sanitizeHtml(html: string): string {
  const svgBlocks: string[] = [];
  const safe = html.replace(/<div class="svg-source"[^>]*>[\s\S]*?<\/div>/gi, m => {
    svgBlocks.push(m);
    return `<!--SVG_PLACEHOLDER_${svgBlocks.length - 1}-->`;
  });
  const sanitized = safe
    .replace(/<(\/?)(style)(\s|>)/gi, '&lt;$1$2$3')
    .replace(/<(\/?)(script)(\s|>)/gi, '&lt;$1$2$3');
  return sanitized.replace(/<!--SVG_PLACEHOLDER_(\d+)-->/g, (_, i) => svgBlocks[Number(i)]);
}

// Build model data for catalog
const models = modelDirs.map(dir => {
  const modelPath = path.join(docsDir, dir);
  const modelMd = fs.readFileSync(path.join(modelPath, 'model_documentation.md'), 'utf-8');
  const title = extractModelTitle(modelMd, dir);

  // Extract workspace from metadata
  const workspace = extractWorkspace(modelMd) || '';
  const workspaceSlug = toUrlSlug(workspace || 'default');
  const modelSlug = toUrlSlug(dir);

  // Count doc files
  const fileCount = fs.readdirSync(modelPath).filter(f => f.endsWith('.md')).length;

  const marked = createMarked(workspaceSlug, modelSlug, modelPath);
  const previewHtml = sanitizeHtml(marked.parse(modelMd) as string);

  return { slug: dir, title, workspace, workspaceSlug, modelSlug, fileCount, previewHtml };
});

// Collect unique workspaces
const workspaces = [...new Set(models.map(m => m.workspace).filter(Boolean))].sort();
---

<BaseLayout
  title="SemaDoc Data Catalog – Power BI Semantic Model Documentation"
  description="Enterprise data catalog for Power BI: Browse automatically generated documentation for your Semantic Models – tables, measures, DAX, Power Query & more."
  locale={locale}
  currentPath="docs-example"
  keywords="SemaDoc, data catalog, Power BI documentation, Semantic Model, DAX, Power Query, measures, table documentation"
>
  <script is:inline>(function(){if(localStorage.getItem('semadoc-theme')==='dark')document.documentElement.classList.add('dark');})()</script>
  <section class="py-12 bg-neutral-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <p class="text-sm font-medium text-accent-600 mb-2 tracking-wide uppercase">SemaDoc</p>
          <div class="flex items-center gap-2">
            <button id="help-toggle" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title={strings.catalog.help}>
              <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </button>
            <button id="dark-toggle" type="button" class="p-2 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-100 transition-colors" title="Dark / Light Mode">
              <svg class="dark-icon-moon w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
              <svg class="dark-icon-sun hidden w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </button>
          </div>
        </div>
        <h1 class="text-3xl font-bold text-primary-700 mb-2">{strings.catalog.title}</h1>
        <p class="text-neutral-600">{strings.catalog.subtitle}</p>
      </div>

      <!-- Search Bar -->
      <div class="mb-8">
        <div class="relative">
          <svg class="absolute left-4 top-3.5 w-5 h-5 text-neutral-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="catalog-search"
            placeholder={strings.catalog.search_placeholder}
            class="w-full px-4 py-3 pl-12 border border-neutral-200 rounded-xl bg-white focus:ring-2 focus:ring-accent-400 focus:border-accent-400 outline-none text-neutral-800"
          />
          <button
            id="clear-search"
            class="hidden absolute right-4 top-3.5 text-neutral-400 hover:text-neutral-600"
            title={strings.catalog.clear_search}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Search Results (hidden by default) -->
      <div id="search-results" class="hidden">
        <div class="flex items-center justify-between mb-6">
          <h2 id="search-results-heading" class="text-lg font-semibold text-primary-700"></h2>
        </div>
        <div class="flex flex-col lg:flex-row gap-8">
          <div id="search-results-content" class="w-full lg:w-2/5 flex-shrink-0 overflow-y-auto" style="max-height: 80vh;"></div>
          <div id="search-preview-panel" class="hidden flex-1 min-w-0">
            <div class="lg:sticky lg:top-24">
              <div class="flex items-center justify-between mb-3 gap-2">
                <h3 id="preview-heading" class="text-sm font-semibold text-primary-700 truncate"></h3>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <a id="preview-open-link" href="#" class="inline-flex items-center gap-1 px-3 py-1.5 bg-accent-600 text-white text-xs font-medium rounded-lg hover:bg-accent-500 transition-colors whitespace-nowrap">
                    {strings.catalog.open_document}
                  </a>
                  <button id="preview-close" type="button" class="p-1.5 rounded-lg border border-neutral-200 hover:bg-neutral-100 transition-colors" title={strings.catalog.close_preview}>
                    <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
              </div>
              <article id="preview-content" class="prose prose-neutral max-w-none bg-white rounded-xl p-6 border border-neutral-100 shadow-sm overflow-y-auto" style="max-height: 70vh;"></article>
            </div>
          </div>
        </div>
      </div>

      <!-- Catalog Browser -->
      <div id="catalog-browser" class="flex flex-col md:flex-row gap-8">
        <!-- Left: Model List -->
        <aside class="w-full md:w-80 flex-shrink-0">
          <!-- Workspace Filter -->
          {workspaces.length > 1 && (
            <div class="mb-4">
              <label for="workspace-filter" class="text-xs font-medium text-neutral-500 uppercase tracking-wide mb-1 block">{strings.catalog.workspace_label}</label>
              <select id="workspace-filter" class="w-full px-3 py-2 border border-neutral-200 rounded-lg bg-white text-sm text-neutral-700 focus:ring-2 focus:ring-accent-400 focus:border-accent-400 outline-none">
                <option value="">{strings.catalog.all_workspaces}</option>
                {workspaces.map(ws => (
                  <option value={ws}>{ws}</option>
                ))}
              </select>
            </div>
          )}

          <h2 class="text-lg font-semibold text-primary-700 mb-4">{strings.catalog.models_heading}</h2>
          <div class="space-y-2" id="model-list">
            {models.map((model, i) => (
              <button
                data-model={model.slug}
                data-workspace={model.workspace}
                class:list={[
                  'model-item w-full text-left px-4 py-3 rounded-xl border transition-all',
                  i === 0
                    ? 'bg-white border-accent-400 shadow-sm ring-1 ring-accent-400/20'
                    : 'bg-white border-neutral-100 hover:border-accent-300 hover:shadow-sm',
                ]}
              >
                <div class="font-medium text-primary-700 text-sm">{model.title}</div>
                <div class="text-xs text-neutral-400 mt-1">
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                    {model.workspace}
                  </span>
                  <span class="ml-2">{model.fileCount} {strings.catalog.documents_label}</span>
                </div>
              </button>
            ))}
          </div>
        </aside>

        <!-- Right: Model Preview -->
        <div class="flex-1 min-w-0">
          {models.length === 0 && (
            <div class="text-center text-neutral-400 py-20">
              {strings.catalog.select_model_hint}
            </div>
          )}
          {models.map((model, i) => (
            <div
              id={`preview-${model.slug}`}
              data-model-url={`/en/docs-example/${model.workspaceSlug}/${model.modelSlug}`}
              class:list={['model-preview', i === 0 ? '' : 'hidden']}
            >
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-4 gap-2">
                <h2 class="text-xl font-bold text-primary-700">{model.title}</h2>
                <a
                  href={`/en/docs-example/${model.workspaceSlug}/${model.modelSlug}`}
                  class="inline-flex items-center gap-1 px-4 py-2 bg-accent-600 text-white text-sm font-medium rounded-lg hover:bg-accent-500 transition-colors whitespace-nowrap"
                >
                  {strings.catalog.view_full_docs}
                </a>
              </div>
              <article class="prose prose-neutral max-w-none bg-white rounded-xl p-8 border border-neutral-100 shadow-sm" set:html={model.previewHtml} />
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Catalog Help Modal -->
    <div id="help-modal" class="hidden fixed inset-0 z-50">
      <div class="absolute inset-0 bg-black/50" id="help-modal-backdrop"></div>
      <div class="absolute inset-4 sm:inset-8 md:inset-16 lg:inset-24 bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden max-w-3xl mx-auto">
        <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-200 flex-shrink-0">
          <h2 class="text-lg font-bold text-primary-700">{strings.catalog.help_catalog_title}</h2>
          <button id="help-modal-close" type="button" class="p-2 rounded-lg hover:bg-neutral-100 transition-colors" title={strings.catalog.close}>
            <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <div class="flex-1 overflow-y-auto p-6">
          <p class="text-neutral-600 mb-6">{strings.catalog.help_catalog_intro}</p>
          <div class="space-y-6">
            <div class="bg-neutral-50 rounded-xl p-5 border border-neutral-100">
              <h3 class="font-semibold text-primary-700 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                {strings.catalog.help_catalog_workspace_title}
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{strings.catalog.help_catalog_workspace_desc}</p>
            </div>
            <div class="bg-neutral-50 rounded-xl p-5 border border-neutral-100">
              <h3 class="font-semibold text-primary-700 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4" /></svg>
                {strings.catalog.help_catalog_model_title}
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{strings.catalog.help_catalog_model_desc}</p>
            </div>
            <div class="bg-neutral-50 rounded-xl p-5 border border-neutral-100">
              <h3 class="font-semibold text-primary-700 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                {strings.catalog.help_catalog_preview_title}
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{strings.catalog.help_catalog_preview_desc}</p>
            </div>
            <div class="bg-neutral-50 rounded-xl p-5 border border-neutral-100">
              <h3 class="font-semibold text-primary-700 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                {strings.catalog.help_catalog_search_title}
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{strings.catalog.help_catalog_search_desc}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Marked.js for client-side markdown preview -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>

  <!-- Mermaid for model previews -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline>
    if (typeof mermaid !== 'undefined') {
      mermaid.initialize({
        startOnLoad: false,
        theme: document.documentElement.classList.contains('dark') ? 'dark' : 'default',
        securityLevel: 'loose',
        flowchart: { useMaxWidth: true },
        er: { useMaxWidth: true },
      });
    }
    window.noop = function() {};
  </script>

  <style is:global>
    .prose pre.mermaid,
    .prose pre.mermaid-source {
      background: transparent;
      border: none;
      padding: 0;
      text-align: center;
      overflow-x: auto;
    }
    .prose pre.mermaid svg {
      max-width: 100%;
      height: auto;
    }
    /* Mermaid zoom & fullscreen */
    .mermaid-wrapper {
      position: relative;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      overflow: hidden;
      margin: 1rem 0;
    }
    .mermaid-viewport {
      overflow: auto;
      padding: 1rem;
      cursor: grab;
      max-height: 70vh;
    }
    .mermaid-viewport.dragging,
    .mermaid-viewport.dragging * {
      cursor: grabbing !important;
      user-select: none;
    }
    .mermaid-viewport > pre.mermaid {
      transform-origin: 0 0;
      display: inline-block;
      min-width: 100%;
    }
    .mermaid-controls {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      display: flex;
      gap: 0.25rem;
      z-index: 10;
    }
    .mermaid-controls button {
      width: 2rem;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      cursor: pointer;
      color: #374151;
      font-size: 1rem;
      line-height: 1;
      transition: background 0.15s, border-color 0.15s;
    }
    .mermaid-controls button:hover {
      background: #f3f4f6;
      border-color: #9ca3af;
    }
    .mermaid-zoom-label {
      width: auto !important;
      padding: 0 0.375rem;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: default !important;
      user-select: none;
    }
    .mermaid-fullscreen-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0,0,0,0.85);
      display: none;
      flex-direction: column;
    }
    .mermaid-fullscreen-overlay.active {
      display: flex;
    }
    .mermaid-fullscreen-header {
      display: flex;
      justify-content: flex-end;
      padding: 0.75rem 1rem;
      gap: 0.25rem;
      background: rgba(0,0,0,0.3);
    }
    .mermaid-fullscreen-header button {
      width: 2rem;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 0.375rem;
      cursor: pointer;
      color: white;
      font-size: 1rem;
      line-height: 1;
      transition: background 0.15s;
    }
    .mermaid-fullscreen-header button:hover {
      background: rgba(255,255,255,0.25);
    }
    .mermaid-fullscreen-body {
      flex: 1;
      overflow: auto;
      padding: 1rem;
      cursor: grab;
    }
    .mermaid-fullscreen-body.dragging,
    .mermaid-fullscreen-body.dragging * {
      cursor: grabbing !important;
      user-select: none;
    }
    .mermaid-fullscreen-body .fs-svg-container {
      background: white;
      border-radius: 0.5rem;
      padding: 1rem;
      display: inline-block;
      margin: 0 auto;
      transform-origin: 0 0;
    }
    /* ── SVG embed styles ── */
    .svg-embed-wrapper {
      position: relative;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      overflow: hidden;
      margin: 1rem 0;
    }
    .svg-embed-viewport {
      overflow: auto;
      padding: 1rem;
      cursor: grab;
      max-height: 70vh;
      text-align: center;
    }
    .svg-embed-viewport.dragging,
    .svg-embed-viewport.dragging * {
      cursor: grabbing !important;
      user-select: none;
    }
    .svg-embed-viewport > .svg-embed-inner {
      transform-origin: 0 0;
      display: inline-block;
      min-width: 100%;
    }
    .svg-embed-viewport svg {
      max-width: 100%;
      height: auto;
    }
    .svg-embed-controls {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      display: flex;
      gap: 0.25rem;
      z-index: 10;
    }
    .svg-embed-controls button {
      width: 2rem;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      cursor: pointer;
      color: #374151;
      font-size: 1rem;
      line-height: 1;
      transition: background 0.15s, border-color 0.15s;
    }
    .svg-embed-controls button:hover {
      background: #f3f4f6;
      border-color: #9ca3af;
    }
    .svg-embed-zoom-label {
      width: auto !important;
      padding: 0 0.375rem;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: default !important;
      user-select: none;
    }
    .svg-embed-controls .svg-pause-btn {
      font-size: 0.875rem;
    }
    html.dark .svg-embed-wrapper { border-color: #475569; }
    html.dark .svg-embed-controls button { background-color: #1e293b; border-color: #475569; color: #e2e8f0; }
    html.dark .svg-embed-controls button:hover { background-color: #334155; }
    .fs-zoom-label {
